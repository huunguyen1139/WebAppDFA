<%@ Page Title="Query data tool" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" CodeBehind="tool.aspx.cs" Inherits="WebApplication2.xk502m7l3" %><%@ Register assembly="DevExpress.Web.v15.1, Version=15.1.5.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" namespace="DevExpress.Web" tagprefix="dx" %>
<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" runat="server">

     <h2><%: Title %>.</h2>
    <h3>Your application description page.</h3>
    <p>Use this area to provide additional information.</p>
     <asp:UpdatePanel ID="UpdatePanel1" runat="server">
         <ContentTemplate>
             <asp:TextBox ID="sqlSentence" runat="server" Height="65px" TextMode="MultiLine" Width="100%" Wrap="False">select * from TA_TimeLog where EmployeeATID in (&#39;00573&#39;,&#39;&#39;) and Time &gt;= &#39;2020-01-01&#39; order by Time desc</asp:TextBox>
<br />
             <p>
                 Choose an type of connection&nbsp;
                 <asp:DropDownList ID="typeofconnection" runat="server" Height="26px" Width="94px">
                     <asp:ListItem Selected="True">erp</asp:ListItem>
                     <asp:ListItem>mrp</asp:ListItem>
                     <asp:ListItem>hr</asp:ListItem>
                 </asp:DropDownList>
                 &nbsp;&nbsp;&nbsp;
                 <asp:TextBox ID="txtDate" runat="server" TextMode="Date" Width="121px"></asp:TextBox>
                 &nbsp;&nbsp;&nbsp;
                 <asp:Button ID="Button1" runat="server" OnClick="Button1_Click" Text="Time Log In" Width="88px" />
                 &nbsp;
                 <asp:Button ID="Button2" runat="server" OnClick="Button2_Click" Text="Time Log Out" Width="94px" />
                 &nbsp;
                 <asp:Button ID="Button3" runat="server" OnClick="Button3_Click" Text="Time Card" Width="89px" />
             </p>
         </ContentTemplate>
     </asp:UpdatePanel>

<p>
    <asp:Button ID="btnQuery" runat="server" Text="Query" Width="89px" OnClick="btnQuery_Click" />
    <asp:CheckBox ID="CheckBox1" runat="server" Text="Show the query result in GridView" Checked="True" CssClass="checkbox-inline" EnableTheming="True" />
</p>
     <p>
</p>
     <asp:UpdatePanel ID="UpdatePanel2" runat="server">
         <ContentTemplate>
             <asp:GridView ID="GridView1" runat="server" BackColor="White" BorderColor="#CCCCCC" BorderStyle="None" BorderWidth="1px" Caption="Result" CellPadding="3" Width="100%" AllowPaging="True" CssClass="table table-hover" OnPageIndexChanging="GridView1_PageIndexChanging">
                 <FooterStyle BackColor="White" ForeColor="#000066" />
                 <HeaderStyle BackColor="Silver" Font-Bold="True" ForeColor="#333333" />
                 <PagerStyle BackColor="White" ForeColor="#000066" HorizontalAlign="Left" />
                 <RowStyle ForeColor="#000066" />
                 <SelectedRowStyle BackColor="#669999" Font-Bold="True" ForeColor="White" />
                 <SortedAscendingCellStyle BackColor="#F1F1F1" />
                 <SortedAscendingHeaderStyle BackColor="#007DBB" />
                 <SortedDescendingCellStyle BackColor="#CAC9C9" />
                 <SortedDescendingHeaderStyle BackColor="#00547E" />
             </asp:GridView>
         </ContentTemplate>
     </asp:UpdatePanel>
<p>
    &nbsp;</p>

</asp:Content>
