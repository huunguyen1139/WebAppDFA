                                <li class="sidebar-item"><a href="KPIResult.aspx?type=TeamLeader" class="sidebar-link"><i class="mdi mdi-border-left"></i><span class="hide-menu">Team Leader </span></a></li>
                                <li class="sidebar-item"><a href="KPIResult.aspx?type=Leader" class="sidebar-link"><i class="mdi mdi-border-left"></i><span class="hide-menu">Line Leader </span></a></li>
