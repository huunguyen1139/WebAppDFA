                                <!-- User profile image -->
                                <div class="profile-img m-auto"><img src="src/assets/images/users/<%: Session["userid"].ToString() %>.jpg" alt="user" class="w-100 rounded-circle" onerror="this.onerror=null; this.src='src/assets/images/users/erroruser.png'"></div>
                                <!-- User profile text-->

                                <div class="profile-text py-1"> <a href="#" class="dropdown-toggle link u-dropdown" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="true"><%: Session["username"].ToString() %> <span class="caret"></span></a>
                                    <div class="dropdown-menu animated flipInY">
                                        <a href="#" class="dropdown-item"><i class="ti-user text-info me-1 ms-1"></i> My Profile</a>
                                        <a href="/kaizen/kaizenlist.aspx" class="dropdown-item" target="_blank"><i class="ti-wallet text-warning me-1 ms-1"></i> My Kaizen</a>
                                        <a href="/default.aspx" class="dropdown-item" target="_blank"><i class="ti-email text-info me-1 ms-1"></i> POR System</a>
                                        <div class="dropdown-divider"></div> <a href="#" class="dropdown-item"><i class="ti-settings text-success me-1 ms-1"></i> Account Setting</a>
                                        <div class="dropdown-divider"></div> <a href="/Account/lockout.aspx" class="dropdown-item"><i class="fa fa-power-off text-danger me-1 ms-1"></i> Logout</a>
                                    </div>
                                </div>
                            </div>
                             <%} %>
                            <!-- End User profile text-->
                        </li>
                        <!-- User Profile-->
                                              
                                                
                       
