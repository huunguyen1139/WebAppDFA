                                <%--<li class="sidebar-item"><a href="table-layout-coloured.html" class="sidebar-link"><i class="mdi mdi-border-bottom"></i><span class="hide-menu">Coloured Table Layout</span></a></li>--%>
                            </ul>
                        </li>
                        <li class="sidebar-item"> <a class="sidebar-link has-arrow waves-effect waves-dark" href="javascript:void(0)" aria-expanded="false"><i data-feather="hard-drive" class="feather-icon"></i><span class="hide-menu">KPI Setup</span></a>
                            <ul aria-expanded="false" class="collapse first-level">
                                <li class="sidebar-item"><a href="KPITeamMember.aspx" class="sidebar-link"><i class="mdi mdi-border-style"></i><span class="hide-menu"> Team member</span></a></li>
                                <li class="sidebar-item"><a href="KPICriteriaSetup.aspx" class="sidebar-link"><i class="mdi mdi-border-vertical"></i><span class="hide-menu"> Criterion</span></a></li>
                                <li class="sidebar-item"><a href="#" class="sidebar-link"><i class="mdi mdi-blur-linear"></i><span class="hide-menu"> Point</span></a></li>
                                <li class="sidebar-item"><a href="#" class="sidebar-link"><i class="mdi mdi-border-style"></i><span class="hide-menu"> Employee</span></a></li>
                            </ul>
                        </li>
                        <li class="sidebar-item"> <a class="sidebar-link waves-effect waves-dark sidebar-link" href="KPIViolateRecord.aspx" aria-expanded="false"><i data-feather="disc" class="feather-icon"></i><span class="hide-menu">Violation Record</span></a></li>
                       <li class="sidebar-item"> <a class="sidebar-link waves-effect waves-dark sidebar-link" href="/ReportViewer?type=kpiresult" target="_blank" aria-expanded="false"><i data-feather="smartphone" class="feather-icon"></i><span class="hide-menu">View Result List</span></a></li>
                        <li class="sidebar-item"> <a class="sidebar-link waves-effect waves-dark sidebar-link" href="Productivity.aspx" aria-expanded="false"><i data-feather="command" class="feather-icon"></i><span class="hide-menu">Productivity Bonus</span></a></li>
